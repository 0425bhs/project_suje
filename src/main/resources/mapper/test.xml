<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kh.suje.dao.TestDAO">
    <select id="getCategoryList"
            resultType="test">
        SELECT *
        FROM categories
        WHERE parent_id IS NULL
    </select>
    <select id="getCategoryListById"
            parameterType="int"
            resultType="test">
        SELECT *
        FROM categories
        WHERE parent_id = #{parent_id}
    </select>
</mapper>