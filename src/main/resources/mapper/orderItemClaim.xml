<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kh.suje.dao.OrderItemClaimDAO">

    <!-- 교환/환불 생성 -->
    <insert id="insertClaim" parameterType="orderitemclaim" useGeneratedKeys="true"
            keyProperty="claim_id" keyColumn="claim_id">
        INSERT INTO order_item_claims (
            order_item_id,
            status,
            reason,
            detail_reason
        )
        VALUES (
            #{order_item_id},
            #{status},
            #{reason},
            #{detail_reason} )
    </insert>

   
    
</mapper>
