<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.kh.suje.dao.ProductDAO">
	
    <select id="product_list" resultType="product">
        SELECT id,seller_id,category_id,name,description,price,stock,delivery_fee,status,image_l,image_s,created_at,updated_at
        FROM products WHERE status='APPROVED'
    </select>
		
</mapper>